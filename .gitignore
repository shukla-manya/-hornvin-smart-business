# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/

# Yarn Berry (if adopted later)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# -----------------------------------------------------------------------------
# Environment & secrets (never commit real credentials)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets.json
credentials.json
service-account*.json

# -----------------------------------------------------------------------------
# Build & compiled output
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Logs & diagnostics
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Tests & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.vitest/
playwright-report/
test-results/
blob-report/

# -----------------------------------------------------------------------------
# Expo / React Native (mobile/)
# -----------------------------------------------------------------------------
.expo/
.expo-shared/
web-build/

# Metro
.metro-health-check*

# Native folders after `expo prebuild` / bare workflow
**/ios/Pods/
**/ios/build/
**/ios/*.xcworkspace/xcuserdata/
**/ios/*.xcodeproj/xcuserdata/
**/ios/*.xcodeproj/project.xcworkspace/xcuserdata/
**/ios/DerivedData/

**/android/app/build/
**/android/build/
**/android/.gradle/
**/android/local.properties
**/android/captures/
**/android/.cxx/
**/android/*.iml
**/android/.idea/

# Keystores (release); keep debug.keystore if your template relies on it
*.jks
*.keystore
!**/debug.keystore

# Fastlane (if used)
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/**/*.png
**/fastlane/test_output

# EAS / Expo Application Services
.eas/

# -----------------------------------------------------------------------------
# Backend / local data (server/)
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
dump.rdb

# MongoDB Memory Server downloads (tests)
.mongo-memory-server/

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editors & tooling
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# VS Code / Cursor — local user settings (uncomment if you never commit workspace settings)
# .vscode/*
# !.vscode/extensions.json
# !.vscode/settings.json
# !.vscode/launch.json
# !.vscode/tasks.json

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.orig
*.rej
*.patch.apply
tmp/
temp/
*.tmp
*.temp
.eslintcache
.stylelintcache
